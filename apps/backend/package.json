{
  "name": "@storm-demo/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "dev:noaa": "wrangler dev --env noaa --port 8787",
    "build": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply StormDemo --local",
    "db:migrate:remote": "wrangler d1 migrations apply StormDemo --remote",
    "db:migrate:create": "wrangler d1 migrations create StormDemo"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
